<%- include('partials/header') %>

<div class="container admin-page">
    <div style="display: flex; justify-content: space-between; align-items: center; background: white; padding: 20px 30px; border-radius: 16px; margin-bottom: 30px; box-shadow: var(--shadow); border: 1px solid #f1f5f9;">
        <div class="header-text">
            <h2 style="margin: 0; color: var(--dark); font-size: 1.8rem;">Shop Configuration 🛠️</h2>
            <p style="margin: 5px 0 0 0; color: var(--slate); font-size: 0.9rem;">Manage your profile, services, and staff team.</p>
        </div>
        <a href="/owner/requests" class="btn-auth" style="padding: 12px 25px; width: auto; font-size: 0.9rem; background: var(--secondary);">
            <i class="fas fa-calendar-check"></i> View Bookings
        </a>
    </div>

    <div style="display: flex; gap: 12px; margin-bottom: 30px; overflow-x: auto; padding-bottom: 10px;">
        <button onclick="openTab('setup')" class="tab-btn-modern active-tab" id="btn-setup">
            <i class="fas fa-store"></i> 1. Shop Setup
        </button>
        <button onclick="openTab('services')" class="tab-btn-modern" id="btn-services">
            <i class="fas fa-cut"></i> 2. Manage Services
        </button>
        <button onclick="openTab('employees')" class="tab-btn-modern" id="btn-employees">
            <i class="fas fa-users"></i> 3. Manage Staff
        </button>
    </div>

    <div id="setup" class="tab-content-box admin-card">
        <div class="card-header">
            <h3>Salon Information</h3>
            <p>Update your shop's primary details and location.</p>
        </div>
        <form action="/owner/setup-shop" method="POST" enctype="multipart/form-data" class="admin-form">
            <div class="form-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px;">
                <div class="form-group">
                    <label>Shop Name</label>
                    <div class="input-wrapper">
                        <i class="fas fa-heading"></i>
                        <input type="text" name="shopName" placeholder="Elite Hair Studio" value="<%= shop ? shop.shopName : '' %>" required>
                    </div>
                </div>
                <div class="form-group">
                    <label>Full Address</label>
                    <div class="input-wrapper">
                        <i class="fas fa-map-marker-alt"></i>
                        <input type="text" name="address" placeholder="123 Salon St, City" value="<%= shop ? shop.address : '' %>" required>
                    </div>
                </div>
                <div class="form-group">
                    <label>Opening Time</label>
                    <div class="input-wrapper">
                        <i class="far fa-clock"></i>
                        <input type="text" name="openingTime" placeholder="09:00 AM" value="<%= shop ? shop.openingTime : '' %>" required>
                    </div>
                </div>
                <div class="form-group">
                    <label>Closing Time</label>
                    <div class="input-wrapper">
                        <i class="fas fa-moon"></i>
                        <input type="text" name="closingTime" placeholder="09:00 PM" value="<%= shop ? shop.closingTime : '' %>" required>
                    </div>
                </div>
                <div class="form-group">
                    <label>Longitude</label>
                    <div class="input-wrapper">
                        <i class="fas fa-location-arrow"></i>
                        <input type="text" name="longitude" value="<%= (shop && shop.location) ? shop.location.coordinates[0] : '' %>" required>
                    </div>
                </div>
                <div class="form-group">
                    <label>Latitude</label>
                    <div class="input-wrapper">
                        <i class="fas fa-map-pin"></i>
                        <input type="text" name="latitude" value="<%= (shop && shop.location) ? shop.location.coordinates[1] : '' %>" required>
                    </div>
                </div>
                <div class="form-group" style="grid-column: 1 / -1;">
                    <label>Facilities (Comma separated)</label>
                    <div class="input-wrapper">
                        <i class="fas fa-concierge-bell"></i>
                        <input type="text" name="facilities" placeholder="WiFi, AC, Parking, Music" value="<%= shop ? shop.facilities.join(', ') : '' %>">
                    </div>
                </div>
                <div class="form-group" style="grid-column: 1 / -1;">
                    <label>Shop Banner Image</label>
                    <div class="input-wrapper" style="padding: 10px; border: 1.5px dashed #e2e8f0; border-radius: 10px;">
                        <input type="file" name="bannerImage">
                    </div>
                </div>
            </div>
            <button type="submit" class="btn-auth" style="margin-top: 20px; width: auto; padding: 12px 40px;">
                Update Profile <i class="fas fa-save"></i>
            </button>
        </form>
    </div>

    <div id="services" class="tab-content-box admin-card" style="display:none;">
        <div class="card-header">
            <h3>Add New Service ✂️</h3>
        </div>
        <form action="/owner/add-service" method="POST" enctype="multipart/form-data" class="admin-form" style="background: #f8fafc; padding: 20px; border-radius: 12px; margin-bottom: 30px;">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px;">
                <input type="text" name="serviceName" placeholder="Service Name" required class="input-field-custom">
                <input type="number" name="price" placeholder="Price (₹)" required class="input-field-custom">
                <input type="number" name="duration" placeholder="Duration (Mins)" required class="input-field-custom">
                <input type="text" name="description" placeholder="Short description..." style="grid-column: span 2;" class="input-field-custom">
                <input type="file" name="serviceImage">
            </div>
            <button type="submit" class="btn-auth" style="margin-top: 15px; width: auto;">➕ Add Service</button>
        </form>

        <h4 style="border-left: 4px solid var(--primary); padding-left: 15px; margin-bottom: 20px;">Live Menu</h4>
        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Price</th>
                        <th>Time</th>
                    </tr>
                </thead>
                <tbody>
                    <% services.forEach(service => { %>
                        <tr>
                            <td><img src="<%= service.serviceImage %>" width="45" height="45" style="border-radius: 8px; object-fit: cover;"></td>
                            <td style="font-weight: 600;"><%= service.serviceName %></td>
                            <td style="color: var(--secondary); font-weight: bold;">₹<%= service.price %></td>
                            <td><span class="status-pill pending"><%= service.duration %> mins</span></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <div id="employees" class="tab-content-box admin-card" style="display:none;">
        <div class="card-header">
            <h3>Onboard New Staff 🧑‍🎨</h3>
        </div>
        <form action="/owner/add-employee" method="POST" class="admin-form" style="background: #f8fafc; padding: 20px; border-radius: 12px; margin-bottom: 30px;">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px;">
                <input type="text" name="name" placeholder="Full Name" required class="input-field-custom">
                <input type="text" name="specialty" placeholder="e.g. Beard Specialist" required class="input-field-custom">
                <input type="text" name="phone" placeholder="Contact No" required class="input-field-custom">
                <select name="isAvailable" class="input-field-custom">
                    <option value="true">Available Now ✅</option>
                    <option value="false">On Leave ❌</option>
                </select>
            </div>
            <button type="submit" class="btn-auth" style="margin-top: 15px; width: auto; background: var(--secondary);">➕ Add Member</button>
        </form>

        <h4 style="border-left: 4px solid var(--secondary); padding-left: 15px; margin-bottom: 20px;">Current Team</h4>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px;">
            <% employees.forEach(emp => { %>
                <div class="admin-card" style="border-left: 6px solid <%= emp.isAvailable ? '#10b981' : '#ef4444' %>;">
                    <div style="display: flex; gap: 15px; align-items: center;">
                        <div class="stat-icon" style="background: #f1f5f9; color: var(--slate);"><i class="fas fa-user-tie"></i></div>
                        <div>
                            <h4 style="margin: 0;"><%= emp.name %></h4>
                            <p style="margin: 2px 0; color: var(--primary); font-size: 0.8rem; font-weight: 700;"><%= emp.specialty %></p>
                            <span class="status-pill <%= emp.isAvailable ? 'active' : 'expired' %>">
                                <%= emp.isAvailable ? 'Active' : 'Away' %>
                            </span>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</div>

<style>
    /* 🎨 Component Specific Styles */
    .tab-btn-modern {
        padding: 12px 24px; border-radius: 10px; border: 1px solid #e2e8f0;
        background: white; color: var(--slate); font-weight: 600; cursor: pointer;
        transition: var(--transition); display: flex; align-items: center; gap: 8px;
    }
    .active-tab { background: var(--primary); color: white; border-color: var(--primary); box-shadow: 0 4px 12px rgba(59, 130, 246, 0.2); }
    
    .input-field-custom {
        padding: 12px; border: 1.5px solid #e2e8f0; border-radius: 10px;
        font-size: 0.9rem; font-family: inherit; outline: none;
    }
    .input-field-custom:focus { border-color: var(--primary); }
</style>

<script>
    function openTab(tabName) {
        const contents = document.getElementsByClassName("tab-content-box");
        for (let i = 0; i < contents.length; i++) { contents[i].style.display = "none"; }
        
        const buttons = document.getElementsByClassName("tab-btn-modern");
        for (let i = 0; i < buttons.length; i++) { buttons[i].classList.remove("active-tab"); }
        
        document.getElementById(tabName).style.display = "block";
        document.getElementById('btn-' + tabName).classList.add("active-tab");
    }
</script>

<%- include('partials/footer') %>