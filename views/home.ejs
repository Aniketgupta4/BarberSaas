<%- include('partials/header') %>

<style>
    /* 🎨 Design System Variables */
    :root {
        --primary: #3b82f6;
        --primary-dark: #1d4ed8;
        --secondary: #10b981;
        --dark: #0f172a;
        --slate: #64748b;
        --light: #f8fafc;
        --white: #ffffff;
        --shadow-sm: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        --shadow-md: 0 10px 25px -5px rgba(0, 0, 0, 0.08);
        --shadow-lg: 0 25px 50px -12px rgba(59, 130, 246, 0.15);
        --transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    body { font-family: 'Inter', system-ui, sans-serif; background-color: var(--light); color: var(--dark); overflow-x: hidden; }

    /* 🌟 Smooth Load Animation */
    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .fade-up { animation: fadeUp 0.8s ease-out forwards; }
    .delay-1 { animation-delay: 0.1s; }
    .delay-2 { animation-delay: 0.2s; }

    /* 🚀 Hero Section */
    .hero { padding: 100px 0 140px; background: linear-gradient(135deg, #ffffff 0%, #f1f5f9 100%); position: relative; }
    .hero::before { content: ''; position: absolute; top: -10%; right: -5%; width: 400px; height: 400px; background: radial-gradient(circle, rgba(59, 130, 246, 0.15) 0%, transparent 70%); border-radius: 50%; z-index: 0; }
    .hero-container { display: grid; grid-template-columns: 1fr 1fr; align-items: center; gap: 60px; position: relative; z-index: 1; }

    .hero-content h1 { font-size: 4rem; font-weight: 900; line-height: 1.1; margin-bottom: 24px; color: var(--dark); letter-spacing: -1px; }
    .hero-content h1 span { background: linear-gradient(to right, var(--primary), #8b5cf6); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .hero-content p { font-size: 1.2rem; color: var(--slate); line-height: 1.7; margin-bottom: 40px; max-width: 500px; }

    .hero-btns { display: flex; gap: 16px; }
    .btn-primary-custom { background: var(--primary); color: white; padding: 16px 36px; border-radius: 14px; font-weight: 700; text-decoration: none; box-shadow: 0 10px 20px -5px rgba(59, 130, 246, 0.4); transition: var(--transition); cursor: pointer; }
    .btn-secondary-custom { background: var(--white); color: var(--dark); padding: 16px 36px; border-radius: 14px; font-weight: 700; text-decoration: none; border: 2px solid #e2e8f0; transition: var(--transition); cursor: pointer; }
    .btn-primary-custom:hover { transform: translateY(-3px); background: var(--primary-dark); box-shadow: 0 15px 25px -5px rgba(59, 130, 246, 0.5); }
    .btn-secondary-custom:hover { background: var(--light); border-color: var(--slate); transform: translateY(-3px); }

    /* 🎡 Modern Carousel */
    .hero-carousel { position: relative; border-radius: 30px; overflow: hidden; box-shadow: var(--shadow-lg); height: 500px; transform: perspective(1000px) rotateY(-5deg); transition: var(--transition); }
    .hero-carousel:hover { transform: perspective(1000px) rotateY(0deg); }
    .carousel-container { height: 100%; position: relative; }
    .carousel-slide { position: absolute; inset: 0; opacity: 0; transition: opacity 0.8s ease-in-out, transform 0.8s ease; transform: scale(1.05); }
    .carousel-slide.active { opacity: 1; transform: scale(1); }
    .carousel-slide img { width: 100%; height: 100%; object-fit: cover; }
    .carousel-btn { position: absolute; top: 50%; transform: translateY(-50%); background: rgba(255, 255, 255, 0.2); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.3); color: white; padding: 15px; border-radius: 50%; cursor: pointer; z-index: 10; transition: var(--transition); }
    .carousel-btn:hover { background: var(--white); color: var(--dark); }
    .carousel-btn.prev { left: 20px; }
    .carousel-btn.next { right: 20px; }

    /* 🔍 Search Bar */
    .search-wrapper { margin-top: -60px; position: relative; z-index: 10; padding: 0 20px; }
    .search-card { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(16px); padding: 12px; border-radius: 20px; box-shadow: var(--shadow-lg); display: flex; align-items: center; gap: 12px; border: 1px solid rgba(255,255,255,0.5); max-width: 900px; margin: 0 auto; }
    .search-input-group { flex: 2; display: flex; align-items: center; background: var(--light); padding: 15px 20px; border-radius: 14px; transition: 0.3s; border: 1px solid transparent; }
    .search-input-group:focus-within { background: white; border-color: var(--primary); box-shadow: 0 0 0 4px rgba(59,130,246,0.1); }
    .search-input-group i { color: var(--primary); margin-right: 12px; font-size: 1.2rem; }
    .search-input-group input { border: none; background: transparent; outline: none; width: 100%; font-size: 1.05rem; font-weight: 500; color: var(--dark); }
    
    .gps-btn { flex: 1; display: flex; align-items: center; justify-content: center; gap: 10px; background: #eff6ff; color: var(--primary); padding: 15px 20px; border-radius: 14px; cursor: pointer; font-weight: 700; transition: 0.3s; min-width: 160px; border: 1px solid transparent; }
    .gps-btn:hover { background: #dbeafe; }
    .gps-btn.loading { opacity: 0.7; cursor: wait; }
    .gps-btn.active { background: #dcfce7; color: #15803d; border-color: #22c55e; }
    .main-search-btn { background: var(--dark); color: white; padding: 15px 35px; border-radius: 14px; font-weight: 800; border: none; cursor: pointer; transition: 0.3s; font-size: 1.05rem; }
    .main-search-btn:hover { background: var(--primary); transform: translateY(-2px); }

    /* ✨ Features & Shops */
    .features { padding: 100px 0; background: var(--white); }
    .section-header { text-align: center; margin-bottom: 60px; }
    .section-header h2 { font-size: 2.8rem; font-weight: 900; margin-bottom: 16px; color: var(--dark); }
    .section-header p { color: var(--slate); font-size: 1.15rem; }
    .features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; }
    .feature-card { background: var(--white); padding: 45px 30px; border-radius: 24px; border: 1px solid #f1f5f9; transition: var(--transition); text-align: center; box-shadow: var(--shadow-sm); }
    .feature-card:hover { transform: translateY(-10px); box-shadow: var(--shadow-md); border-color: #bfdbfe; }
    .f-icon { width: 70px; height: 70px; background: linear-gradient(135deg, #eff6ff, #dbeafe); color: var(--primary); border-radius: 20px; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; margin: 0 auto 24px; }
    .feature-card h3 { font-size: 1.4rem; font-weight: 800; margin-bottom: 12px; }
    .feature-card p { color: var(--slate); line-height: 1.6; }

    .shop-section { padding: 100px 0; background: var(--light); }
    .shop-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 35px; }
    .shop-card { background: var(--white); border-radius: 24px; overflow: hidden; border: 1px solid #e2e8f0; transition: var(--transition); box-shadow: var(--shadow-sm); display: flex; flex-direction: column; }
    .shop-card:hover { transform: translateY(-12px); box-shadow: var(--shadow-md); }
    .shop-img { height: 220px; position: relative; overflow: hidden; }
    .shop-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
    .shop-card:hover .shop-img img { transform: scale(1.08); }
    .distance-badge { position: absolute; top: 16px; left: 16px; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px); padding: 6px 12px; border-radius: 10px; font-size: 0.75rem; font-weight: 800; color: var(--primary); }
    .shop-status { position: absolute; top: 16px; right: 16px; color: white; padding: 6px 14px; border-radius: 10px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; }
    
    .shop-info { padding: 25px; display: flex; flex-direction: column; flex-grow: 1; }
    .shop-info h3 { font-size: 1.4rem; margin-bottom: 12px; font-weight: 800; color: var(--dark); }
    .shop-info p { display: flex; align-items: center; gap: 10px; color: var(--slate); font-size: 0.95rem; margin-bottom: 8px; font-weight: 500; }
    .shop-info i { color: var(--primary); width: 18px; text-align: center; }
    .facilities { display: flex; gap: 8px; flex-wrap: wrap; margin: 15px 0 25px; }
    .facilities span { background: #f1f5f9; color: var(--dark); padding: 6px 12px; border-radius: 8px; font-size: 0.75rem; font-weight: 700; border: 1px solid #e2e8f0; }
    .btn-book { margin-top: auto; display: flex; justify-content: center; align-items: center; gap: 8px; width: 100%; background: #f8fafc; color: var(--dark); padding: 14px; border-radius: 12px; text-decoration: none; font-weight: 800; transition: var(--transition); border: 1px solid #e2e8f0; }
    .btn-book:hover { background: var(--dark); color: var(--white); border-color: var(--dark); }

    /* 🛑 POPUP MODAL STYLES */
    .modal-overlay {
        position: fixed; inset: 0; background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(8px);
        display: none; justify-content: center; align-items: center; z-index: 1000;
        opacity: 0; transition: opacity 0.3s ease;
    }
    .modal-overlay.active { display: flex; opacity: 1; }
    
    .contact-modal {
        background: white; width: 90%; max-width: 450px; border-radius: 24px; padding: 40px;
        text-align: center; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        transform: translateY(20px) scale(0.95); transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        position: relative;
    }
    .modal-overlay.active .contact-modal { transform: translateY(0) scale(1); }
    .modal-close { position: absolute; top: 15px; right: 15px; width: 35px; height: 35px; background: #f1f5f9; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--slate); font-size: 1.2rem; cursor: pointer; transition: 0.3s; }
    .modal-close:hover { background: #e2e8f0; color: var(--danger); transform: rotate(90deg); }
    .modal-icon { width: 80px; height: 80px; background: #eff6ff; color: var(--primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem; margin: 0 auto 20px; box-shadow: 0 0 0 10px rgba(59,130,246,0.1); }
    .contact-modal h2 { font-size: 1.8rem; font-weight: 900; color: var(--dark); margin-bottom: 10px; }
    .contact-modal p { color: var(--slate); line-height: 1.6; margin-bottom: 30px; font-size: 1.05rem; }
    .admin-card { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 16px; padding: 20px; margin-bottom: 25px; }
    .admin-card h4 { font-size: 1.2rem; font-weight: 800; color: var(--dark); margin: 0 0 5px; }
    .admin-card .phone { font-size: 1.4rem; font-weight: 900; color: var(--primary); font-family: monospace; letter-spacing: 1px; }
    .contact-btns { display: flex; gap: 15px; justify-content: center; }
    .btn-call { flex: 1; display: flex; align-items: center; justify-content: center; gap: 8px; background: var(--dark); color: white; padding: 14px; border-radius: 12px; text-decoration: none; font-weight: 700; transition: 0.3s; }
    .btn-whatsapp { flex: 1; display: flex; align-items: center; justify-content: center; gap: 8px; background: #25D366; color: white; padding: 14px; border-radius: 12px; text-decoration: none; font-weight: 700; transition: 0.3s; }
    .btn-call:hover { background: #000; transform: translateY(-2px); }
    .btn-whatsapp:hover { background: #128C7E; transform: translateY(-2px); }

    /* Responsive */
    @media (max-width: 1024px) {
        .hero-container { grid-template-columns: 1fr; text-align: center; }
        .hero-content p { margin: 0 auto 40px; }
        .hero-btns { justify-content: center; }
        .features-grid { grid-template-columns: repeat(2, 1fr); }
        .hero-carousel { transform: none; height: 400px; }
    }
    @media (max-width: 768px) {
        .hero-content h1 { font-size: 2.8rem; }
        .search-card { flex-direction: column; padding: 20px; border-radius: 24px; }
        .search-input-group, .gps-btn, .main-search-btn { width: 100%; }
        .features-grid { grid-template-columns: 1fr; }
        .hero-carousel { height: 300px; }
    }
</style>

<section class="hero">
    <div class="container hero-container fade-up">
        <div class="hero-content">
            <h1>Premium Style, <br><span>Zero Waiting.</span></h1>
            <p>Experience the future of grooming. Discover the finest barbers in your city, book instantly, and skip the queue forever.</p>
            <div class="hero-btns">
                <a href="#shops" class="btn-primary-custom">Explore Shops</a>
                <button onclick="openModal()" class="btn-secondary-custom">Join as Barber</button>
            </div>
        </div>

        <div class="hero-carousel fade-up delay-1">
            <div class="carousel-container" id="carousel">
                <div class="carousel-slide active">
                    <img src="https://images.unsplash.com/photo-1503951914875-452162b0f3f1?auto=format&fit=crop&w=800&q=80" alt="Slide 1">
                </div>
                <div class="carousel-slide">
                    <img src="https://images.unsplash.com/photo-1585747860715-2ba37e788b70?auto=format&fit=crop&w=800&q=80" alt="Slide 2">
                </div>
                <div class="carousel-slide">
                    <img src="https://images.unsplash.com/photo-1512690118299-a65117880bb7?auto=format&fit=crop&w=800&q=80" alt="Slide 3">
                </div>
                <button class="carousel-btn prev" onclick="changeSlide(-1)"><i class="fas fa-chevron-left"></i></button>
                <button class="carousel-btn next" onclick="changeSlide(1)"><i class="fas fa-chevron-right"></i></button>
            </div>
        </div>
    </div>
</section>

<div class="modal-overlay" id="contactModal">
    <div class="contact-modal">
        <div class="modal-close" onclick="closeModal()">
            <i class="fas fa-times"></i>
        </div>
        <div class="modal-icon"><i class="fas fa-crown"></i></div>
        <h2>Partner With Us</h2>
        <p>Want to list your barbershop on our platform? Get in touch with our Admin to activate your premium membership.</p>
        <div class="admin-card">
            <h4>Aniket Gupta</h4>
            <div class="phone">+91 8770191425</div>
        </div>
        <div class="contact-btns">
            <a href="tel:8770191425" class="btn-call"><i class="fas fa-phone-alt"></i> Call Now</a>
            <a href="https://wa.me/918770191425?text=Hi%20Aniket,%20I%20want%20to%20register%20my%20barbershop%20on%20your%20platform." target="_blank" class="btn-whatsapp">
                <i class="fab fa-whatsapp" style="font-size: 1.2rem;"></i> WhatsApp
            </a>
        </div>
    </div>
</div>

<div class="search-wrapper fade-up delay-2">
    <form action="/" method="GET" class="search-card">
        <div class="search-input-group">
            <i class="fas fa-search"></i>
            <input type="text" name="query" placeholder="Search by shop name, service, or area..." value="<%= typeof query !== 'undefined' ? query : '' %>">
        </div>
        
        <div class="gps-btn" id="btnLocation">
            <i class="fas fa-location-arrow"></i>
            <span id="locTxt">Near Me</span>
        </div>
        
        <input type="hidden" name="lat" id="inpLat">
        <input type="hidden" name="lng" id="inpLng">
        
        <button type="submit" class="main-search-btn">Search Now</button>
    </form>
</div>

<section class="features">
    <div class="container">
        <div class="section-header fade-up">
            <h2>Fast, Simple, Premium</h2>
            <p>Getting your fresh look is now just three clicks away.</p>
        </div>
        <div class="features-grid">
            <div class="feature-card fade-up">
                <div class="f-icon"><i class="fas fa-map-marked-alt"></i></div>
                <h3>Find Your Style</h3>
                <p>Browse top-rated barbers near your current location with precision GPS.</p>
            </div>
            <div class="feature-card fade-up delay-1">
                <div class="f-icon"><i class="fas fa-calendar-check"></i></div>
                <h3>Instant Booking</h3>
                <p>Pick a date and time that fits your busy life instantly without phone calls.</p>
            </div>
            <div class="feature-card fade-up delay-2">
                <div class="f-icon"><i class="fas fa-star"></i></div>
                <h3>Priority Service</h3>
                <p>Show up, skip the waiting line, and get treated like a VIP every time.</p>
            </div>
        </div>
    </div>
</section>

<section id="shops" class="shop-section">
    <div class="container">
        <div class="section-header" style="text-align: left;">
            <h2>Verified Barbershops</h2>
            <p>Handpicked professionals ready for your styling needs.</p>
        </div>

        <div class="shop-grid">
            <% if (shops && shops.length > 0) { %>
                <% shops.forEach(shop => { 
                    
                    // 🔴 SMART EXPIRY LOGIC FOR ALL ACCOUNTS
                    let isExpired = false;
                    let today = new Date();
                    
                    if (shop.ownerId && typeof shop.ownerId === 'object') {
                        if (shop.ownerId.isActive === false) {
                            isExpired = true;
                        } else if (shop.ownerId.subscriptionEnd && new Date(shop.ownerId.subscriptionEnd) < today) {
                            isExpired = true;
                        }
                    }
                %>
                
                    <div class="shop-card fade-up" style="<%= isExpired || shop.isOpen === false ? 'opacity: 0.8; filter: grayscale(40%);' : '' %>">
                        <div class="shop-img">
                            <img src="<%= (shop.bannerImage && shop.bannerImage !== 'default-shop.jpg') ? shop.bannerImage : 'https://images.unsplash.com/photo-1512690196252-741ed2f49d4d?auto=format&fit=crop&w=800&q=80' %>" alt="<%= shop.shopName %>">
                            
                            <% if (isExpired) { %>
                                <span class="shop-status" style="background: var(--danger); box-shadow: 0 4px 6px rgba(239,68,68,0.3);">UNAVAILABLE</span>
                            <% } else if (shop.isOpen === false) { %>
                                <span class="shop-status" style="background: #f59e0b; box-shadow: 0 4px 6px rgba(245,158,11,0.3);">CLOSED NOW</span>
                            <% } else { %>
                                <span class="shop-status" style="background: var(--secondary); box-shadow: 0 4px 6px rgba(16,185,129,0.3);">ACTIVE</span>
                            <% } %>
                            
                            <% if (shop.dist) { %>
                                <div class="distance-badge">
                                    <i class="fas fa-location-arrow"></i> <%= (shop.dist.calculated / 1000).toFixed(1) %> km
                                </div>
                            <% } %>
                        </div>
                        
                        <div class="shop-info">
                            <h3><%= shop.shopName %></h3>
                            
                            <div style="display: flex; align-items: center; gap: 5px; margin-bottom: 10px; color: #fbbf24; font-weight: 800; font-size: 0.95rem;">
                                <i class="fas fa-star"></i>
                                <span style="color: var(--dark);"><%= shop.averageRating > 0 ? shop.averageRating.toFixed(1) : 'New' %></span>
                                <span style="color: var(--slate); font-weight: 600; font-size: 0.8rem; margin-left: 4px;">(<%= shop.totalReviews %> Reviews)</span>
                            </div>
                            <p><i class="fas fa-map-marker-alt"></i> <%= shop.address %></p>
                            <p><i class="far fa-clock"></i> <%= shop.openingTime %> - <%= shop.closingTime %></p>
                            
                            <div class="facilities">
                                <% if (shop.facilities && shop.facilities.length > 0) { %>
                                    <% shop.facilities.slice(0, 3).forEach(facility => { %>
                                        <span><%= facility %></span>
                                    <% }) %>
                                <% } else { %>
                                    <span>Premium Tools</span><span>AC</span>
                                <% } %>
                            </div>

                            <% if (isExpired) { %>
                                <button class="btn-book" style="background: #cbd5e1; cursor: not-allowed; border-color: #cbd5e1; color: #475569;" disabled>Shop Unavailable</button>
                            <% } else if (shop.isOpen === false) { %>
                                <button class="btn-book" style="background: #fef3c7; color: #d97706; border-color: #fcd34d; cursor: not-allowed;" disabled>Currently Closed</button>
                            <% } else { %>
                                <a href="/shop/<%= shop._id %>" class="btn-book">
                                    View Services <i class="fas fa-arrow-right" style="font-size: 0.8rem;"></i>
                                </a>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="empty-state" style="grid-column: 1/-1; text-align: center; padding: 80px 20px; background: white; border-radius: 24px; border: 2px dashed #e2e8f0;">
                    <i class="fas fa-search-location" style="font-size: 4rem; color: #cbd5e1; margin-bottom: 20px;"></i>
                    <h3 style="font-size: 1.8rem; color: var(--dark);">No shops found in this area</h3>
                    <p style="color: var(--slate); margin-top: 10px;">Try adjusting your search or enabling GPS to find nearby barbers.</p>
                    <a href="/" style="display: inline-block; margin-top: 20px; color: var(--primary); font-weight: 800; text-decoration: none;">Clear Search Filters</a>
                </div>
            <% } %>
        </div>
    </div>
</section>

<script>
    // Modal Logic
    const modal = document.getElementById('contactModal');
    function openModal() {
        modal.classList.add('active');
        document.body.style.overflow = 'hidden'; 
    }
    function closeModal() {
        modal.classList.remove('active');
        document.body.style.overflow = 'auto';
    }
    modal.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
    });

    // Carousel Logic
    let currentSlide = 0;
    const slides = document.querySelectorAll('.carousel-slide');
    function changeSlide(direction) {
        slides[currentSlide].classList.remove('active');
        currentSlide = (currentSlide + direction + slides.length) % slides.length;
        slides[currentSlide].classList.add('active');
    }
    setInterval(() => changeSlide(1), 5000);

    // GPS Logic
    const btnLoc = document.getElementById('btnLocation');
    const txtLoc = document.getElementById('locTxt');
    const inpLat = document.getElementById('inpLat');
    const inpLng = document.getElementById('inpLng');

    btnLoc.addEventListener('click', () => {
        if (navigator.geolocation) {
            btnLoc.classList.add('loading');
            txtLoc.innerText = "Locating...";
            
            navigator.geolocation.getCurrentPosition(
                (position) => {
                    inpLat.value = position.coords.latitude;
                    inpLng.value = position.coords.longitude;
                    txtLoc.innerText = "Location Found ✅";
                    btnLoc.classList.remove('loading');
                    btnLoc.classList.add('active');
                },
                (err) => {
                    btnLoc.classList.remove('loading');
                    alert("Please allow location access to find nearby shops.");
                    txtLoc.innerText = "Access Denied ❌";
                },
                { enableHighAccuracy: true, timeout: 5000 }
            );
        } else {
            alert("Browser doesn't support GPS.");
        }
    });

    // Scroll Animations
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.style.animationPlayState = 'running';
                observer.unobserve(entry.target);
            }
        });
    });

    document.querySelectorAll('.fade-up').forEach(el => {
        el.style.animationPlayState = 'paused';
        observer.observe(el);
    });
</script>

<%- include('partials/footer') %>