<%- include('partials/header') %>

<style>
    /* 🎨 Design System Variables */
    :root {
        --primary: #3b82f6;
        --primary-dark: #1d4ed8;
        --secondary: #10b981;
        --dark: #0f172a;
        --slate: #64748b;
        --light: #f8fafc;
        --white: #ffffff;
        --shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    body { font-family: 'Inter', system-ui, sans-serif; background-color: var(--white); color: var(--dark); }

    /* 🚀 Hero Section */
    .hero {
        padding: 80px 0 120px;
        background: radial-gradient(circle at top right, #eff6ff, transparent),
                    radial-gradient(circle at bottom left, #f0fdf4, transparent);
        overflow: hidden;
    }

    .hero-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        align-items: center;
        gap: 60px;
    }

    .hero-content h1 {
        font-size: 3.5rem;
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 24px;
        color: var(--dark);
    }

    .hero-content h1 span {
        color: var(--primary);
        position: relative;
    }

    .hero-content p {
        font-size: 1.15rem;
        color: var(--slate);
        line-height: 1.7;
        margin-bottom: 40px;
        max-width: 540px;
    }

    .hero-btns { display: flex; gap: 16px; }
    
    .btn-primary-custom {
        background: var(--primary);
        color: white;
        padding: 16px 32px;
        border-radius: 14px;
        font-weight: 700;
        text-decoration: none;
        box-shadow: 0 10px 15px -3px rgba(59, 130, 246, 0.3);
        transition: var(--transition);
    }

    .btn-secondary-custom {
        background: var(--white);
        color: var(--dark);
        padding: 16px 32px;
        border-radius: 14px;
        font-weight: 700;
        text-decoration: none;
        border: 1px solid #e2e8f0;
        transition: var(--transition);
    }

    .btn-primary-custom:hover { transform: translateY(-3px); background: var(--primary-dark); }
    .btn-secondary-custom:hover { background: var(--light); border-color: var(--slate); }

    /* 🎡 Modern Carousel */
    .hero-carousel {
        position: relative;
        border-radius: 30px;
        overflow: hidden;
        box-shadow: var(--shadow);
        height: 480px;
    }

    .carousel-container { height: 100%; position: relative; }
    .carousel-slide {
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity 0.8s ease-in-out;
    }
    .carousel-slide.active { opacity: 1; }
    .carousel-slide img { width: 100%; height: 100%; object-fit: cover; }

    .carousel-btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        color: white;
        padding: 15px;
        border-radius: 50%;
        cursor: pointer;
        z-index: 10;
        transition: var(--transition);
    }
    .carousel-btn:hover { background: var(--white); color: var(--dark); }
    .carousel-btn.prev { left: 20px; }
    .carousel-btn.next { right: 20px; }

    /* ✨ Features Section */
    .features { padding: 100px 0; background: var(--white); }
    .section-header { text-align: center; margin-bottom: 60px; }
    .section-header h2 { font-size: 2.5rem; font-weight: 800; margin-bottom: 16px; }
    .section-header p { color: var(--slate); font-size: 1.1rem; }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 32px;
    }

    .feature-card {
        background: var(--white);
        padding: 40px;
        border-radius: 24px;
        border: 1px solid #f1f5f9;
        transition: var(--transition);
        text-align: center;
    }

    .feature-card:hover {
        transform: translateY(-10px);
        box-shadow: var(--shadow);
        border-color: var(--primary);
    }

    .f-icon {
        width: 64px;
        height: 64px;
        background: #eff6ff;
        color: var(--primary);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin: 0 auto 24px;
    }

    /* 🏬 Shop Section */
    .shop-section { padding: 100px 0; background: #fcfcfc; }
    .shop-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 32px;
    }

    .shop-card {
        background: var(--white);
        border-radius: 24px;
        overflow: hidden;
        border: 1px solid #f1f5f9;
        transition: var(--transition);
    }

    .shop-card:hover { transform: translateY(-12px); box-shadow: var(--shadow); }

    .shop-img { height: 240px; position: relative; }
    .shop-img img { width: 100%; height: 100%; object-fit: cover; }
    
    .shop-status {
        position: absolute;
        top: 16px;
        right: 16px;
        background: var(--secondary);
        color: white;
        padding: 6px 14px;
        border-radius: 10px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .shop-info { padding: 28px; }
    .shop-info h3 { font-size: 1.4rem; margin-bottom: 12px; font-weight: 700; }
    .shop-info p { display: flex; align-items: center; gap: 10px; color: var(--slate); font-size: 0.95rem; margin-bottom: 8px; }
    .shop-info i { color: var(--primary); width: 18px; }

    .facilities { display: flex; gap: 8px; flex-wrap: wrap; margin: 20px 0; }
    .facilities span {
        background: #f1f5f9;
        color: #475569;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .btn-book {
        display: block;
        width: 100%;
        text-align: center;
        background: var(--dark);
        color: var(--white);
        padding: 14px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 700;
        transition: var(--transition);
    }

    .btn-book:hover { background: var(--primary); transform: scale(1.02); }

    /* 📱 Responsive */
    @media (max-width: 1024px) {
        .hero-container { grid-template-columns: 1fr; text-align: center; }
        .hero-content p { margin: 0 auto 40px; }
        .hero-btns { justify-content: center; }
        .features-grid { grid-template-columns: 1fr 1fr; }
    }

    @media (max-width: 768px) {
        .hero-content h1 { font-size: 2.5rem; }
        .features-grid { grid-template-columns: 1fr; }
        .hero-carousel { height: 350px; }
    }
</style>

<section class="hero">
    <div class="container hero-container">
        <div class="hero-content">
            <h1>Premium Style, <br><span>Zero Waiting.</span></h1>
            <p>Experience the future of grooming. Discover the finest barbers in your city, book instantly, and skip the queue forever.</p>
            <div class="hero-btns">
                <a href="#shops" class="btn-primary-custom">Explore Shops</a>
                <a href="/signup" class="btn-secondary-custom">Join as Barber</a>
            </div>
        </div>

        <div class="hero-carousel">
            <div class="carousel-container" id="carousel">
                <div class="carousel-slide active">
                    <img src="https://images.unsplash.com/photo-1503951914875-452162b0f3f1?auto=format&fit=crop&w=800&q=80" alt="Slide 1">
                </div>
                <div class="carousel-slide">
                    <img src="https://images.unsplash.com/photo-1585747860715-2ba37e788b70?auto=format&fit=crop&w=800&q=80" alt="Slide 2">
                </div>

                <button class="carousel-btn prev" onclick="changeSlide(-1)"><i class="fas fa-chevron-left"></i></button>
                <button class="carousel-btn next" onclick="changeSlide(1)"><i class="fas fa-chevron-right"></i></button>
            </div>
        </div>
    </div>
</section>

<section class="features">
    <div class="container">
        <div class="section-header">
            <h2>Fast, Simple, Premium</h2>
            <p>Getting your fresh look is now just three clicks away.</p>
        </div>
        <div class="features-grid">
            <div class="feature-card">
                <div class="f-icon"><i class="fas fa-search"></i></div>
                <h3>Find Your Style</h3>
                <p>Browse top-rated barbers near your current location with ease.</p>
            </div>
            <div class="feature-card">
                <div class="f-icon"><i class="fas fa-calendar-check"></i></div>
                <h3>Instant Booking</h3>
                <p>Pick a date and time that fits your busy life instantly.</p>
            </div>
            <div class="feature-card">
                <div class="f-icon"><i class="fas fa-check-circle"></i></div>
                <h3>Priority Service</h3>
                <p>Show up, skip the line, and get treated like a VIP.</p>
            </div>
        </div>
    </div>
</section>

<section id="shops" class="shop-section">
    <div class="container">
        <div class="section-header" style="text-align: left;">
            <h2>Featured Barbershops</h2>
            <p>Handpicked professionals for your styling needs.</p>
        </div>

        <div class="shop-grid">
            <% if (shops && shops.length > 0) { %>
                <% shops.forEach(shop => { %>
                    <div class="shop-card">
                        <div class="shop-img">
                            <img src="<%= (shop.bannerImage && shop.bannerImage !== 'default-shop.jpg') ? shop.bannerImage : 'https://images.unsplash.com/photo-1512690196252-741ed2f49d4d?auto=format&fit=crop&w=800&q=80' %>" alt="<%= shop.shopName %>">
                            <span class="shop-status">Active</span>
                        </div>
                        
                        <div class="shop-info">
                            <h3><%= shop.shopName %></h3>
                            <p><i class="fas fa-map-marker-alt"></i> <%= shop.address %></p>
                            <p><i class="far fa-clock"></i> <%= shop.openingTime %> - <%= shop.closingTime %></p>
                            
                            <div class="facilities">
                                <% if (shop.facilities && shop.facilities.length > 0) { %>
                                    <% shop.facilities.slice(0, 3).forEach(facility => { %>
                                        <span><%= facility %></span>
                                    <% }) %>
                                <% } else { %>
                                    <span>Premium Tools</span><span>AC</span>
                                <% } %>
                            </div>

                            <a href="/shop/<%= shop._id %>" class="btn-book">View Services</a>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="empty-state" style="grid-column: 1/-1; text-align: center; padding: 60px;">
                    <i class="fas fa-store-slash" style="font-size: 3rem; color: #cbd5e1; margin-bottom: 20px;"></i>
                    <h3>Coming Soon to Your Area</h3>
                    <p>We are expanding rapidly! Check back soon for new openings.</p>
                </div>
            <% } %>
        </div>
    </div>
</section>

<script>
    let currentSlide = 0;
    const slides = document.querySelectorAll('.carousel-slide');

    function changeSlide(direction) {
        slides[currentSlide].classList.remove('active');
        currentSlide = (currentSlide + direction + slides.length) % slides.length;
        slides[currentSlide].classList.add('active');
    }

    // Auto Play
    setInterval(() => changeSlide(1), 5000);
</script>

<%- include('partials/footer') %>