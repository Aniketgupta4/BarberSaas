<%- include('partials/header') %>

<div class="container admin-page">
    <div class="dashboard-header-flex">
        <div class="user-profile-summary">
            <div class="user-avatar-large">
                <i class="fas fa-user-tie"></i>
            </div>
            <div class="welcome-text">
                <h1>Welcome back, <%= user.name %>! 👋</h1>
                <div class="sub-status">
                    <span class="status-pill <%= user.isActive ? 'active' : 'expired' %>">
                        <%= user.isActive ? 'Active Plan' : 'Plan Expired' %>
                    </span>
                    <p>Valid Till: <strong><%= user.subscriptionEnd ? user.subscriptionEnd.toDateString() : 'N/A' %></strong></p>
                </div>
            </div>
        </div>
        
        <div class="stats-container">
            <div class="stat-card">
                <span class="stat-value"><%= typeof services !== 'undefined' ? services.length : 0 %></span>
                <span class="stat-label">Live Services</span>
            </div>
        </div>
    </div>

    <% if (!shop) { %>
        <div class="setup-container">
            <div class="admin-card setup-card">
                <div class="card-header">
                    <div class="header-icon"><i class="fas fa-store-alt"></i></div>
                    <h3>Setup Your Shop Profile</h3>
                    <p>Tell us about your salon to start accepting bookings.</p>
                </div>
                <a href="/owner/manage" class="btn-admin-submit" style="text-decoration: none; text-align: center; display: block; margin-top: 20px;">
                    Go to Shop Setup <i class="fas fa-arrow-right"></i>
                </a>
            </div>
        </div>

    <% } else { %>
        <div class="admin-main-grid">
            
            <div class="dashboard-left-column">
                <div class="admin-card shop-overview-card" style="margin-bottom: 25px;">
                    <div class="shop-preview-banner">
                        <img src="<%= shop.bannerImage %>" alt="Shop Banner">
                    </div>
                    <div class="shop-card-info">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                            <h3><%= shop.shopName %></h3>
                            <span class="badge-status">Online</span>
                        </div>
                        <p class="loc"><i class="fas fa-map-marker-alt"></i> <%= shop.address %></p>
                        <div class="timing-pills">
                            <span><i class="far fa-sun"></i> <%= shop.openingTime %></span>
                            <span><i class="far fa-moon"></i> <%= shop.closingTime %></span>
                        </div>
                        <a href="/owner/manage" class="btn-edit-shop">
                            Shop Settings <i class="fas fa-cog"></i>
                        </a>
                    </div>
                </div>

                <div class="admin-card">
                    <div class="card-header">
                        <h3>Latest Updates 📣</h3>
                    </div>
                    <div class="recent-notice">
                        <i class="fas fa-info-circle"></i>
                        <p>Check the <strong>Requests</strong> tab to see new customer bookings. Keep your status 'Online' to get more visibility!</p>
                    </div>
                </div>
            </div>

            <div class="admin-card dashboard-actions">
                <div class="card-header">
                    <h3>Quick Actions ⚡</h3>
                    <p>Access your main tools quickly</p>
                </div>

                <div class="action-buttons-grid">
                    <a href="/owner/requests" class="action-btn-large">
                        <div class="a-icon" style="background: #eef2ff; color: #4f46e5;"><i class="fas fa-calendar-check"></i></div>
                        <div class="a-text">
                            <strong>Manage Bookings</strong>
                            <span>Approve or Reschedule requests</span>
                        </div>
                    </a>
                    <a href="/owner/manage" class="action-btn-large">
                        <div class="a-icon" style="background: #f0fdf4; color: #16a34a;"><i class="fas fa-cut"></i></div>
                        <div class="a-text">
                            <strong>Service Menu</strong>
                            <span>Edit prices and grooming options</span>
                        </div>
                    </a>
                    <a href="/owner/manage" class="action-btn-large">
                        <div class="a-icon" style="background: #fff7ed; color: #ea580c;"><i class="fas fa-users-cog"></i></div>
                        <div class="a-text">
                            <strong>Staff & Employees</strong>
                            <span>Manage your barber team</span>
                        </div>
                    </a>
                    <a href="/" class="action-btn-large">
                        <div class="a-icon" style="background: #fef2f2; color: #dc2626;"><i class="fas fa-external-link-alt"></i></div>
                        <div class="a-text">
                            <strong>Public Preview</strong>
                            <span>See how customers see your shop</span>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    <% } %>
</div>

<%- include('partials/footer') %>