<%- include('partials/header') %>

<style>
    :root {
        --primary: #3b82f6;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --dark: #0f172a;
        --slate: #64748b;
        --purple: #8b5cf6; 
    }

    .dashboard-page { padding: 40px 0; background: #f8fafc; min-height: 100vh; }
    
    /* 👤 Profile Header */
    .dashboard-header-flex { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; flex-wrap: wrap; gap: 20px; }
    .user-profile-summary { display: flex; align-items: center; gap: 20px; }
    .user-avatar-large { 
        width: 70px; height: 70px; background: linear-gradient(135deg, var(--primary), #8b5cf6); 
        color: white; display: flex; align-items: center; justify-content: center; 
        border-radius: 20px; font-size: 1.8rem; font-weight: 800; box-shadow: 0 10px 20px rgba(59, 130, 246, 0.2); 
    }
    
    /* 📊 Stats Section */
    .stats-container { display: flex; gap: 15px; flex-wrap: wrap; }
    .stat-card { background: white; padding: 15px 25px; border-radius: 16px; border: 1px solid #e2e8f0; text-align: center; min-width: 100px; }
    
    .stat-card.highlighted { 
        background: var(--primary); 
        border-color: var(--primary); 
        box-shadow: 0 8px 15px -3px rgba(59, 130, 246, 0.4);
    }
    .stat-card.highlighted .stat-value,
    .stat-card.highlighted .stat-label { 
        color: #ffffff !important; 
        opacity: 1; 
    }

    .stat-value { display: block; font-size: 1.5rem; font-weight: 800; color: var(--dark); }
    .stat-label { font-size: 0.7rem; text-transform: uppercase; font-weight: 700; opacity: 0.7; letter-spacing: 1px; color: var(--slate); }

    /* 📅 Booking Cards */
    .section-title-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; }
    .btn-book-new { background: var(--primary); color: white; padding: 12px 24px; border-radius: 12px; font-weight: 700; text-decoration: none; transition: 0.3s; }
    .btn-book-new:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(59, 130, 246, 0.3); }

    .bookings-grid { display: flex; flex-direction: column; gap: 20px; }
    .booking-item-card { 
        background: white; border-radius: 20px; padding: 25px; display: flex; 
        justify-content: space-between; align-items: center; border: 1px solid #f1f5f9; 
        position: relative; transition: 0.3s; 
    }
    .booking-item-card:hover { transform: scale(1.01); box-shadow: 0 15px 30px rgba(0,0,0,0.05); }
    
    /* Status Styling */
    .status-accepted { border-left: 8px solid var(--success); }
    .status-pending { border-left: 8px solid var(--slate); }
    .status-rescheduled { border-left: 8px solid var(--warning); }
    .status-rejected { border-left: 8px solid var(--danger); }
    .status-completed { border-left: 8px solid var(--purple); } 

    .shop-icon-circle { width: 50px; height: 50px; background: #eff6ff; color: var(--primary); display: flex; align-items: center; justify-content: center; border-radius: 14px; font-size: 1.2rem; }
    
    .main-info h4 { font-size: 1.25rem; font-weight: 800; color: var(--dark); margin: 0 0 5px 0; }
    .shop-name { color: var(--primary); font-weight: 700; font-size: 0.9rem; margin-bottom: 3px; }
    .shop-location { color: var(--slate); font-size: 0.85rem; margin-bottom: 12px; display: flex; align-items: center; gap: 5px; }

    /* 🕒 Meta Info */
    .time-meta { display: flex; gap: 15px; color: var(--dark); font-size: 0.85rem; font-weight: 700; background: #f8fafc; padding: 8px 15px; border-radius: 10px; width: fit-content; }
    .time-meta i { color: var(--primary); }

    /* 📅 Reschedule Alert Box */
    .reschedule-box { 
        margin-top: 20px; background: #fffbeb; border: 1px dashed var(--warning); 
        padding: 15px; border-radius: 12px; color: #92400e; font-size: 0.9rem; 
        display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px;
    }
    .btn-confirm-res { background: var(--warning); color: white; border: none; padding: 8px 16px; border-radius: 8px; cursor: pointer; font-weight: 700; transition: 0.2s; }

    .card-right { text-align: right; display: flex; flex-direction: column; align-items: flex-end; gap: 10px; }
    .price-info { font-size: 1.6rem; font-weight: 900; color: var(--success); margin-bottom: -5px; }
    .status-pill { display: inline-block; padding: 5px 14px; border-radius: 10px; font-size: 0.65rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; }
    
    /* Status Pills */
    .pill-accepted { background: #d1fae5; color: #065f46; }
    .pill-pending { background: #f1f5f9; color: #475569; }
    .pill-rescheduled { background: #fef3c7; color: #92400e; }
    .pill-rejected { background: #fee2e2; color: #991b1b; }
    .pill-completed { background: #ede9fe; color: #5b21b6; } 

    /* Cancel Button */
    .btn-cancel-booking { background: white; color: var(--danger); border: 1px solid var(--danger); padding: 6px 14px; border-radius: 8px; cursor: pointer; font-weight: 700; font-size: 0.75rem; transition: 0.3s; margin-top: 5px; width: 100%; }
    .btn-cancel-booking:hover { background: var(--danger); color: white; }

    /* ⭐ RATING UI STYLES */
    .rating-box { margin-top: 10px; background: #f8fafc; padding: 12px 18px; border-radius: 12px; border: 1px dashed #cbd5e1; display: inline-block; text-align: right; }
    .star-rating-form { display: flex; flex-direction: row-reverse; justify-content: flex-end; gap: 5px; }
    .star-rating-form input { display: none; }
    .star-rating-form label { cursor: pointer; font-size: 1.5rem; color: #cbd5e1; transition: 0.2s; }
    .star-rating-form input:checked ~ label,
    .star-rating-form label:hover,
    .star-rating-form label:hover ~ label { color: var(--warning); }
    .btn-submit-rating { background: var(--dark); color: white; border: none; padding: 8px 16px; border-radius: 8px; margin-left: 15px; font-weight: 700; cursor: pointer; font-size: 0.8rem; transition: 0.3s; }
    .btn-submit-rating:hover { background: var(--primary); }

    /* Pagination UI */
    .pagination-container { display: flex; justify-content: center; align-items: center; gap: 15px; margin-top: 40px; }
    .page-btn { padding: 10px 20px; background: white; border: 1px solid #cbd5e1; border-radius: 10px; color: var(--dark); text-decoration: none; font-weight: 700; transition: 0.3s; }
    .page-btn:hover { background: #f1f5f9; border-color: var(--slate); }
    .page-indicator { padding: 10px 20px; background: var(--primary); color: white; border-radius: 10px; font-weight: 800; box-shadow: 0 4px 10px rgba(59,130,246,0.3); }

    @media (max-width: 768px) {
        .booking-item-card { flex-direction: column; align-items: flex-start; gap: 20px; }
        .card-right { width: 100%; text-align: left; display: flex; flex-direction: row; justify-content: space-between; align-items: center; border-top: 1px solid #f1f5f9; padding-top: 15px; flex-wrap: wrap; }
        .dashboard-header-flex { text-align: center; justify-content: center; }
        .user-profile-summary { flex-direction: column; }
        .stats-container { width: 100%; justify-content: center; }
        .rating-box { text-align: left; }
    }
</style>

<div class="dashboard-page">
    <div class="container">
        <div class="dashboard-header-flex">
            <div class="user-profile-summary">
                <div class="user-avatar-large">
                    <%= user.name.charAt(0).toUpperCase() %>
                </div>
                <div class="welcome-text">
                    <h1 style="margin: 0; font-weight: 900;">Hey, <%= user.name %>! 👋</h1>
                    <p style="margin: 5px 0 0; color: var(--slate);">Here's what's happening with your style schedule.</p>
                </div>
            </div>

            <div class="stats-container">
                <div class="stat-card">
                    <span class="stat-value"><%= appointments ? appointments.length : 0 %></span>
                    <span class="stat-label">Total</span>
                </div>
                <div class="stat-card highlighted">
                    <span class="stat-value">
                        <%= appointments ? appointments.filter(a => a.status === 'Accepted').length : 0 %>
                    </span>
                    <span class="stat-label">Upcoming</span>
                </div>
                <div class="stat-card">
                    <span class="stat-value">
                        <%= appointments ? appointments.filter(a => a.status === 'Completed').length : 0 %>
                    </span>
                    <span class="stat-label">Completed</span>
                </div>
            </div>
        </div>

        <div class="bookings-wrapper">
            <div class="section-title-bar">
                <h3 style="font-weight: 800; color: var(--dark);"><i class="fas fa-history" style="color: var(--primary);"></i> Booking History</h3>
                <a href="/" class="btn-book-new">Book New Service <i class="fas fa-plus" style="font-size: 0.8rem; margin-left: 5px;"></i></a>
            </div>

            <div class="bookings-grid">
                <% if (appointments && appointments.length > 0) { %>
                    <% appointments.forEach(app => { %>
                        <div class="booking-item-card status-<%= app.status ? app.status.toLowerCase() : 'pending' %>">
                            <div style="display: flex; gap: 20px; align-items: flex-start;">
                                <div class="shop-icon-circle">
                                    <i class="fas fa-magic"></i>
                                </div>
                                <div class="main-info">
                                    <h4><%= app.serviceId ? app.serviceId.serviceName : 'Service Deleted' %></h4>
                                    <p class="shop-name">🏪 <%= app.shopId ? app.shopId.shopName : 'Shop Unavailable' %></p>
                                    <p class="shop-location">
                                        <i class="fas fa-map-marker-alt"></i> 
                                        <%= app.shopId ? app.shopId.address : 'Location missing' %>
                                    </p>
                                    
                                    <div class="time-meta">
                                        <span><i class="far fa-calendar-alt"></i> <%= new Date(app.bookingDate).toDateString() %></span>
                                        <span><i class="far fa-clock"></i> <%= app.bookingTime %></span>
                                    </div>

                                    <% if (app.status === 'Rescheduled' && app.bookingDate && app.bookingTime) { %>
                                        <div class="reschedule-box">
                                            <span>
                                                <i class="fas fa-exclamation-circle"></i> 
                                                Barber suggested a new time. Do you agree?
                                            </span>
                                            <form action="/user/confirm-reschedule" method="POST" style="margin: 0;">
                                                <input type="hidden" name="appointmentId" value="<%= app._id %>">
                                                <button type="submit" class="btn-confirm-res">Accept New Time</button>
                                            </form>
                                        </div>
                                    <% } %>
                                </div>
                            </div>

                            <div class="card-right">
                                <div class="price-info">₹<%= app.serviceId ? app.serviceId.price : '0' %></div>
                                <div class="status-pill pill-<%= app.status ? app.status.toLowerCase() : 'pending' %>">
                                    <%= app.status %>
                                </div>
                                
                                <% if (app.status === 'Accepted') { %>
                                    <div style="color: var(--success); font-size: 0.75rem; font-weight: 800; margin-top: 5px;">
                                        <i class="fas fa-check-double"></i> Ready to go!
                                    </div>
                                <% } else if (app.status === 'Completed') { %>
                                    
                                    <% if (app.isRated) { %>
                                        <div style="color: var(--warning); font-size: 0.85rem; font-weight: 800; margin-top: 5px; background: #fffbeb; padding: 5px 12px; border-radius: 8px;">
                                            <i class="fas fa-star"></i> You Rated: <%= app.rating %> Stars
                                        </div>
                                    <% } else { %>
                                        <div class="rating-box">
                                            <p style="margin: 0 0 5px; font-size: 0.7rem; font-weight: 700; color: var(--slate); text-transform: uppercase;">Rate your experience</p>
                                            <form action="/user/rate-service" method="POST" style="margin: 0; display: flex; align-items: center;">
                                                <input type="hidden" name="appointmentId" value="<%= app._id %>">
                                                <div class="star-rating-form">
                                                    <input type="radio" id="star5-<%= app._id %>" name="rating" value="5" required><label for="star5-<%= app._id %>"><i class="fas fa-star"></i></label>
                                                    <input type="radio" id="star4-<%= app._id %>" name="rating" value="4"><label for="star4-<%= app._id %>"><i class="fas fa-star"></i></label>
                                                    <input type="radio" id="star3-<%= app._id %>" name="rating" value="3"><label for="star3-<%= app._id %>"><i class="fas fa-star"></i></label>
                                                    <input type="radio" id="star2-<%= app._id %>" name="rating" value="2"><label for="star2-<%= app._id %>"><i class="fas fa-star"></i></label>
                                                    <input type="radio" id="star1-<%= app._id %>" name="rating" value="1"><label for="star1-<%= app._id %>"><i class="fas fa-star"></i></label>
                                                </div>
                                                <button type="submit" class="btn-submit-rating">Submit</button>
                                            </form>
                                        </div>
                                    <% } %>
                                    <% } %>

                                <% if (app.status === 'Pending' || app.status === 'Rescheduled') { %>
                                    <form action="/user/delete-booking/<%= app._id %>" method="POST" onsubmit="return confirm('Are you sure you want to cancel this booking?');">
                                        <button type="submit" class="btn-cancel-booking">
                                            <i class="fas fa-times"></i> Cancel Booking
                                        </button>
                                    </form>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div style="text-align: center; padding: 80px 20px; background: white; border-radius: 24px; border: 2px dashed #e2e8f0;">
                        <div style="font-size: 3rem; color: #cbd5e1; margin-bottom: 20px;"><i class="fas fa-calendar-times"></i></div>
                        <h3 style="color: var(--dark); font-weight: 800;">No appointments yet</h3>
                        <p style="color: var(--slate); margin-bottom: 25px;">Time for a fresh look? Discover the best shops around you.</p>
                        <a href="/" class="btn-book-new">Browse Barbershops</a>
                    </div>
                <% } %>
            </div>

            <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
                <div class="pagination-container">
                    <% if (currentPage > 1) { %>
                        <a href="/user/dashboard?page=<%= currentPage - 1 %>" class="page-btn">
                            <i class="fas fa-chevron-left"></i> Prev
                        </a>
                    <% } %>

                    <span class="page-indicator">
                        Page <%= currentPage %> of <%= totalPages %>
                    </span>

                    <% if (currentPage < totalPages) { %>
                        <a href="/user/dashboard?page=<%= currentPage + 1 %>" class="page-btn">
                            Next <i class="fas fa-chevron-right"></i>
                        </a>
                    <% } %>
                </div>
            <% } %>

        </div>
    </div>
</div>

<%- include('partials/footer') %>