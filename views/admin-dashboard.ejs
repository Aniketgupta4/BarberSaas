<%- include('partials/header') %>

<style>
    :root {
        --primary: #3b82f6;
        --secondary: #10b981;
        --dark: #0f172a;
        --slate: #64748b;
        --danger: #ef4444;
    }

    body { margin: 0; padding: 0; background: #f1f5f9; font-family: 'Inter', system-ui, sans-serif; }

    .admin-page { padding: 15px; max-width: 1300px; margin: auto; }

    /* 📊 Stats Section */
    .admin-stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: 12px;
        margin-bottom: 20px;
    }

    .stat-card {
        background: white;
        padding: 12px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        gap: 10px;
        border: 1px solid #e2e8f0;
    }

    .stat-icon { width: 35px; height: 35px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .stat-info h3 { font-size: 1.1rem; margin: 0; }
    .stat-info p { font-size: 0.7rem; color: var(--slate); margin: 0; font-weight: 600; }

    /* 🏗 Main Layout */
    .admin-main-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 16px;
    }

    @media (min-width: 1024px) {
        .admin-main-grid { grid-template-columns: 320px 1fr; }
    }

    .admin-card { background: white; padding: 20px; border-radius: 16px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); border: 1px solid #f1f5f9; }
    .admin-card h3 { font-size: 1.1rem; margin-bottom: 15px; color: var(--dark); border-bottom: 2px solid #f1f5f9; padding-bottom: 8px; }

    /* 📝 Compact Form */
    .input-wrapper { position: relative; margin-bottom: 12px; }
    .input-wrapper input {
        width: 100%;
        padding: 10px 10px 10px 35px;
        border-radius: 8px;
        border: 1.5px solid #e2e8f0;
        font-size: 0.9rem;
        outline: none;
    }
    .input-wrapper input:focus { border-color: var(--primary); }
    .input-wrapper i { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--slate); font-size: 0.8rem; }

    .btn-admin-submit {
        width: 100%;
        padding: 12px;
        background: var(--secondary);
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: 700;
        cursor: pointer;
        transition: 0.3s;
    }

    /* 📊 Responsive Table */
    .table-responsive { overflow-x: auto; border-radius: 8px; }
    .admin-table { width: 100%; border-collapse: collapse; }
    .admin-table th { background: #f8fafc; padding: 12px 10px; text-align: left; font-size: 0.7rem; text-transform: uppercase; color: var(--slate); font-weight: 700; border-bottom: 2px solid #edf2f7; }
    .admin-table td { padding: 12px 10px; border-bottom: 1px solid #f1f5f9; font-size: 0.85rem; }

    .status-badge { padding: 4px 8px; border-radius: 6px; font-size: 0.65rem; font-weight: 800; }
    .status-active { background: #d1fae5; color: #065f46; }
    .status-expired { background: #fee2e2; color: #991b1b; }

    .btn-renew { background: var(--primary); color: white; border: none; padding: 6px 12px; border-radius: 6px; font-size: 0.75rem; font-weight: 700; cursor: pointer; transition: 0.2s; }
    .btn-delete { background: var(--danger); color: white; border: none; padding: 6px 12px; border-radius: 6px; font-size: 0.75rem; font-weight: 700; cursor: pointer; transition: 0.2s; }
    .btn-renew:hover { background: var(--primary-dark); }
    .btn-delete:hover { opacity: 0.8; }

    /* 🔥 Mobile View: Table to Cards */
    @media (max-width: 650px) {
        .admin-table thead { display: none; }
        .admin-table, .admin-table tbody, .admin-table tr, .admin-table td { display: block; width: 100%; }
        .admin-table tr { margin-bottom: 15px; border: 1px solid #e2e8f0; border-radius: 12px; padding: 10px; background: #fff; }
        .admin-table td { display: flex; justify-content: space-between; align-items: center; padding: 8px 5px; border: none; border-bottom: 1px dashed #f1f5f9; }
        .admin-table td:last-child { border-bottom: none; }
        .admin-table td::before { content: attr(data-label); font-weight: 800; color: var(--slate); font-size: 0.75rem; text-transform: uppercase; }
        
        .action-btns { justify-content: flex-end; width: 100%; } /* Mobile actions alignment */
    }
</style>

<div class="admin-page">
    <div class="admin-stats-grid">
        <div class="stat-card">
            <div class="stat-icon" style="background:#e0f2fe; color:#0ea5e9;"><i class="fas fa-users"></i></div>
            <div class="stat-info">
                <h3><%= typeof totalOwners !== 'undefined' ? totalOwners : 0 %></h3>
                <p>OWNERS</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background:#dcfce7; color:#22c55e;"><i class="fas fa-store"></i></div>
            <div class="stat-info">
                <h3><%= typeof totalShops !== 'undefined' ? totalShops : 0 %></h3>
                <p>SHOPS</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background:#fef3c7; color:#d97706;"><i class="fas fa-calendar-check"></i></div>
            <div class="stat-info">
                <h3><%= typeof totalBookings !== 'undefined' ? totalBookings : 0 %></h3>
                <p>BOOKINGS</p>
            </div>
        </div>
    </div>

    <div class="admin-main-grid">
        <div class="admin-card">
            <h3>New Partner ➕</h3>
            <form action="/admin/add-owner" method="POST">
                <div class="input-wrapper">
                    <i class="fas fa-user"></i>
                    <input type="text" name="name" placeholder="Full Name" required>
                </div>
                <div class="input-wrapper">
                    <i class="fas fa-envelope"></i>
                    <input type="email" name="email" placeholder="Email Address" required>
                </div>
                <div class="input-wrapper">
                    <i class="fas fa-phone"></i>
                    <input type="text" name="phone" placeholder="Phone Number" required>
                </div>
                <div class="input-wrapper">
                    <i class="fas fa-key"></i>
                    <input type="password" name="password" placeholder="Password" required>
                </div>
                <button type="submit" class="btn-admin-submit">Register Partner</button>
            </form>
        </div>

        <div class="admin-card">
            <h3>Registered Partners 🏬</h3>
            <div class="table-responsive">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Partner Details</th>
                            <th>Status</th>
                            <th>Expiry Date</th>
                            <th style="text-align: right;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (owners && owners.length > 0) { %>
                            <% owners.forEach(owner => { %>
                                <tr>
                                    <td data-label="Partner">
                                        <div style="font-weight: 700; color: var(--dark);"><%= owner.name %></div>
                                        <div style="font-size: 0.75rem; color: var(--slate);"><%= owner.email %></div>
                                    </td>
                                    <td data-label="Status">
                                        <span class="status-badge <%= owner.isActive ? 'status-active' : 'status-expired' %>">
                                            <%= owner.isActive ? 'ACTIVE' : 'EXPIRED' %>
                                        </span>
                                    </td>
                                    <td data-label="Expiry">
                                        <span style="font-weight: 600;"><%= owner.subscriptionEnd ? owner.subscriptionEnd.toDateString() : 'No Plan' %></span>
                                    </td>
                                    <td data-label="Action">
                                        <div class="action-btns" style="display: flex; gap: 8px; justify-content: flex-end;">
                                            <form action="/admin/renew-subscription/<%= owner._id %>" method="POST" style="margin: 0;">
                                                <button type="submit" class="btn-renew">Renew 🔄</button>
                                            </form>
                                            <form action="/admin/delete-partner/<%= owner._id %>" method="POST" style="margin: 0;" onsubmit="return confirm('Are you sure you want to delete this partner? This cannot be undone.');">
                                                <button type="submit" class="btn-delete"><i class="fas fa-trash-alt"></i></button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="4" style="text-align: center; color: var(--slate);">No partners found.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
                <div style="display: flex; justify-content: center; align-items: center; gap: 15px; margin-top: 25px;">
                    
                    <% if (currentPage > 1) { %>
                        <a href="/admin/dashboard?page=<%= currentPage - 1 %>" style="padding: 8px 16px; background: white; border: 1px solid #cbd5e1; border-radius: 8px; color: var(--dark); text-decoration: none; font-weight: 700; font-size: 0.85rem; transition: 0.3s;">
                            <i class="fas fa-chevron-left"></i> Prev
                        </a>
                    <% } %>

                    <span style="padding: 8px 16px; background: var(--primary); color: white; border-radius: 8px; font-weight: 700; font-size: 0.85rem; box-shadow: 0 4px 10px rgba(59, 130, 246, 0.3);">
                        Page <%= currentPage %> of <%= totalPages %>
                    </span>

                    <% if (currentPage < totalPages) { %>
                        <a href="/admin/dashboard?page=<%= currentPage + 1 %>" style="padding: 8px 16px; background: white; border: 1px solid #cbd5e1; border-radius: 8px; color: var(--dark); text-decoration: none; font-weight: 700; font-size: 0.85rem; transition: 0.3s;">
                            Next <i class="fas fa-chevron-right"></i>
                        </a>
                    <% } %>
                    
                </div>
            <% } %>

        </div>
    </div>
</div>

<%- include('partials/footer') %>