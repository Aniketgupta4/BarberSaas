<%- include('partials/header') %>

<style>
    :root {
        --primary: #3b82f6;
        --secondary: #10b981;
        --dark: #0f172a;
        --slate: #64748b;
        --danger: #ef4444;
    }

    body { margin: 0; padding: 0; background: #f1f5f9; font-family: 'Inter', system-ui, sans-serif; }

    .admin-page { padding: 15px; max-width: 1300px; margin: auto; }

    /* 👑 God Mode Header */
    .god-header { margin-bottom: 25px; display: flex; align-items: center; gap: 15px; }
    .god-header h2 { margin: 0; font-size: 1.8rem; font-weight: 900; color: var(--dark); }
    .god-badge { background: var(--dark); color: #fbbf24; padding: 5px 12px; border-radius: 8px; font-size: 0.8rem; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; box-shadow: 0 4px 10px rgba(0,0,0,0.15); }

    /* 📊 Stats Section */
    .admin-stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 15px;
        margin-bottom: 25px;
    }

    .stat-card {
        background: white;
        padding: 15px 20px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        gap: 15px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);
        transition: 0.3s;
    }
    .stat-card:hover { transform: translateY(-3px); box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05); }

    .stat-icon { width: 50px; height: 50px; border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 1.4rem; }
    .stat-info h3 { font-size: 1.6rem; font-weight: 900; margin: 0 0 2px 0; color: var(--dark); }
    .stat-info p { font-size: 0.75rem; color: var(--slate); margin: 0; font-weight: 700; letter-spacing: 0.5px; }

    /* 🏗 Main Layout */
    .admin-main-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 20px;
        margin-bottom: 20px;
    }

    @media (min-width: 1024px) {
        .admin-main-grid { grid-template-columns: 350px 1fr; }
    }

    .admin-card { background: white; padding: 25px; border-radius: 16px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); border: 1px solid #e2e8f0; }
    .admin-card h3 { font-size: 1.2rem; font-weight: 800; margin-bottom: 20px; color: var(--dark); border-bottom: 2px solid #f1f5f9; padding-bottom: 10px; display: flex; align-items: center; justify-content: space-between; }

    /* 📝 Compact Form */
    .input-wrapper { position: relative; margin-bottom: 15px; }
    .input-wrapper input {
        width: 100%;
        padding: 12px 12px 12px 40px;
        border-radius: 10px;
        border: 1.5px solid #e2e8f0;
        font-size: 0.95rem;
        outline: none;
        transition: 0.2s;
        box-sizing: border-box;
    }
    .input-wrapper input:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1); }
    .input-wrapper i { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: var(--slate); font-size: 0.9rem; }

    .btn-admin-submit {
        width: 100%;
        padding: 14px;
        background: var(--dark);
        color: white;
        border: none;
        border-radius: 10px;
        font-weight: 800;
        font-size: 1rem;
        cursor: pointer;
        transition: 0.3s;
    }
    .btn-admin-submit:hover { background: var(--primary); transform: translateY(-2px); }

    /* 📊 Responsive Table */
    .table-responsive { overflow-x: auto; border-radius: 10px; border: 1px solid #f1f5f9; }
    .admin-table { width: 100%; border-collapse: collapse; white-space: nowrap; }
    .admin-table th { background: #f8fafc; padding: 15px; text-align: left; font-size: 0.75rem; text-transform: uppercase; color: var(--slate); font-weight: 800; border-bottom: 2px solid #edf2f7; }
    .admin-table td { padding: 15px; border-bottom: 1px solid #f1f5f9; font-size: 0.9rem; font-weight: 500; color: #1e293b; vertical-align: middle; }
    .admin-table tbody tr:hover { background: #f8fafc; }

    .status-badge { padding: 5px 10px; border-radius: 8px; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; }
    .status-active { background: #dcfce7; color: #166534; }
    .status-expired { background: #fee2e2; color: #991b1b; }
    .status-warning { background: #fef3c7; color: #b45309; }

    .btn-renew { background: var(--primary); color: white; border: none; padding: 8px 14px; border-radius: 8px; font-size: 0.8rem; font-weight: 700; cursor: pointer; transition: 0.2s; }
    .btn-delete { background: var(--danger); color: white; border: none; padding: 8px 14px; border-radius: 8px; font-size: 0.8rem; font-weight: 700; cursor: pointer; transition: 0.2s; }
    .btn-renew:hover { background: var(--primary-dark); transform: scale(1.05); }
    .btn-delete:hover { background: #b91c1c; transform: scale(1.05); }

    .shop-mini-cell { display: flex; align-items: center; gap: 12px; }
    .shop-mini-img { width: 40px; height: 40px; border-radius: 8px; object-fit: cover; }

    /* 🔥 Mobile View: Table to Cards */
    @media (max-width: 768px) {
        .admin-table thead { display: none; }
        .admin-table, .admin-table tbody, .admin-table tr, .admin-table td { display: block; width: 100%; box-sizing: border-box; }
        .admin-table tr { margin-bottom: 15px; border: 1px solid #e2e8f0; border-radius: 12px; padding: 15px; background: #fff; }
        .admin-table td { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border: none; border-bottom: 1px dashed #e2e8f0; }
        .admin-table td:last-child { border-bottom: none; }
        .admin-table td::before { content: attr(data-label); font-weight: 800; color: var(--slate); font-size: 0.75rem; text-transform: uppercase; }
        
        .action-btns { justify-content: flex-end; width: 100%; gap: 10px; }
        .shop-mini-cell { text-align: right; justify-content: flex-end; }
    }
</style>

<div class="admin-page">
    
    <div class="god-header">
        <h2>Platform Overview</h2>
        <span class="god-badge"><i class="fas fa-crown"></i> Superadmin</span>
    </div>

    <div class="admin-stats-grid">
        <div class="stat-card">
            <div class="stat-icon" style="background:#f3e8ff; color:#6366f1;"><i class="fas fa-user-friends"></i></div>
            <div class="stat-info">
                <h3><%= typeof totalCustomers !== 'undefined' ? totalCustomers : 0 %></h3>
                <p>TOTAL CUSTOMERS</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background:#e0f2fe; color:#0ea5e9;"><i class="fas fa-user-tie"></i></div>
            <div class="stat-info">
                <h3><%= typeof totalOwners !== 'undefined' ? totalOwners : 0 %></h3>
                <p>PARTNER OWNERS</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background:#dcfce7; color:#22c55e;"><i class="fas fa-store"></i></div>
            <div class="stat-info">
                <h3><%= typeof totalShops !== 'undefined' ? totalShops : 0 %></h3>
                <p>ACTIVE SHOPS</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background:#fef3c7; color:#d97706;"><i class="fas fa-calendar-check"></i></div>
            <div class="stat-info">
                <h3><%= typeof totalBookings !== 'undefined' ? totalBookings : 0 %></h3>
                <p>TOTAL BOOKINGS</p>
            </div>
        </div>
    </div>

    <div class="admin-main-grid">
        
        <div class="admin-card">
            <h3>New Partner ➕</h3>
            <form action="/admin/add-owner" method="POST">
                <div class="input-wrapper">
                    <i class="fas fa-user"></i>
                    <input type="text" name="name" placeholder="Full Name" required>
                </div>
                <div class="input-wrapper">
                    <i class="fas fa-envelope"></i>
                    <input type="email" name="email" placeholder="Email Address" required>
                </div>
                <div class="input-wrapper">
                    <i class="fas fa-phone"></i>
                    <input type="text" name="phone" placeholder="Phone Number" required>
                </div>
                <div class="input-wrapper">
                    <i class="fas fa-key"></i>
                    <input type="password" name="password" placeholder="Password" required>
                </div>
                <button type="submit" class="btn-admin-submit">Register Partner</button>
            </form>
        </div>

        <div class="admin-card">
            <h3>Registered Partners 🏢</h3>
            <div class="table-responsive">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Partner Details</th>
                            <th>Status</th>
                            <th>Expiry Date</th>
                            <th style="text-align: right;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (owners && owners.length > 0) { %>
                            <% owners.forEach(owner => { 
                                // 🔴 FIX: Check Date Expiry Dynamically
                                let today = new Date();
                                let subEnd = new Date(owner.subscriptionEnd);
                                let isExpired = (owner.isActive === false) || (owner.subscriptionEnd && subEnd < today);
                            %>
                                <tr>
                                    <td data-label="Partner">
                                        <div style="font-weight: 800; color: var(--dark); font-size: 1rem;"><%= owner.name %></div>
                                        <div style="font-size: 0.8rem; color: var(--slate); margin-top: 2px;"><i class="fas fa-envelope"></i> <%= owner.email %></div>
                                    </td>
                                    <td data-label="Status">
                                        <span class="status-badge <%= isExpired ? 'status-expired' : 'status-active' %>">
                                            <%= isExpired ? 'EXPIRED' : 'ACTIVE' %>
                                        </span>
                                    </td>
                                    <td data-label="Expiry">
                                        <span style="font-weight: 700; color: <%= isExpired ? 'var(--danger)' : '#475569' %>;"><%= owner.subscriptionEnd ? owner.subscriptionEnd.toDateString() : 'No Plan' %></span>
                                    </td>
                                    <td data-label="Action">
                                        <div class="action-btns" style="display: flex; gap: 10px; justify-content: flex-end;">
                                            <form action="/admin/renew-subscription/<%= owner._id %>" method="POST" style="margin: 0;">
                                                <button type="submit" class="btn-renew" title="Add 30 Days">Renew 🔄</button>
                                            </form>
                                            <form action="/admin/delete-partner/<%= owner._id %>" method="POST" style="margin: 0;" onsubmit="return confirm('Are you sure you want to delete this partner? This cannot be undone.');">
                                                <button type="submit" class="btn-delete"><i class="fas fa-trash-alt"></i></button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="4" style="text-align: center; color: var(--slate); padding: 30px;">No partners found.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
                <div style="display: flex; justify-content: center; align-items: center; gap: 15px; margin-top: 25px;">
                    <% if (currentPage > 1) { %>
                        <a href="/admin/dashboard?page=<%= currentPage - 1 %>" style="padding: 8px 16px; background: white; border: 1px solid #cbd5e1; border-radius: 8px; color: var(--dark); text-decoration: none; font-weight: 700; font-size: 0.85rem; transition: 0.3s;">
                            <i class="fas fa-chevron-left"></i> Prev
                        </a>
                    <% } %>

                    <span style="padding: 8px 16px; background: var(--dark); color: white; border-radius: 8px; font-weight: 700; font-size: 0.85rem; box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);">
                        Page <%= currentPage %> of <%= totalPages %>
                    </span>

                    <% if (currentPage < totalPages) { %>
                        <a href="/admin/dashboard?page=<%= currentPage + 1 %>" style="padding: 8px 16px; background: white; border: 1px solid #cbd5e1; border-radius: 8px; color: var(--dark); text-decoration: none; font-weight: 700; font-size: 0.85rem; transition: 0.3s;">
                            Next <i class="fas fa-chevron-right"></i>
                        </a>
                    <% } %>
                </div>
            <% } %>
        </div>
    </div>

    <div class="admin-card" style="margin-bottom: 40px;">
        <h3>Platform Shops (Master View) <span class="status-badge status-active"><%= typeof allShops !== 'undefined' ? allShops.length : 0 %> Listed</span></h3>
        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Shop Name</th>
                        <th>Owner</th>
                        <th>Rating</th>
                        <th>Status</th>
                        <th style="text-align: right;">View</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (typeof allShops !== 'undefined' && allShops.length > 0) { %>
                        <% allShops.forEach(shop => { 
                            // 🔴 FIX: Master Table mein bhi Expiry logic laga diya
                            let ownerExpired = false;
                            if(shop.ownerId) {
                                let today = new Date();
                                ownerExpired = shop.ownerId.isActive === false || (shop.ownerId.subscriptionEnd && new Date(shop.ownerId.subscriptionEnd) < today);
                            }
                        %>
                            <tr>
                                <td data-label="Shop Name">
                                    <div class="shop-mini-cell">
                                        <img src="<%= (shop.bannerImage && shop.bannerImage !== 'default-shop.jpg') ? shop.bannerImage : 'https://images.unsplash.com/photo-1512690196252-741ed2f49d4d?w=100' %>" class="shop-mini-img">
                                        <div>
                                            <strong style="display: block; color: var(--dark);"><%= shop.shopName %></strong>
                                            <span style="font-size: 0.75rem; color: var(--slate);"><i class="fas fa-map-marker-alt"></i> <%= shop.address.substring(0, 20) %>...</span>
                                        </div>
                                    </div>
                                </td>
                                <td data-label="Owner">
                                    <span style="font-weight: 600;"><%= shop.ownerId ? shop.ownerId.name : 'Unknown' %></span>
                                </td>
                                <td data-label="Rating">
                                    <div style="color: #f59e0b; font-weight: 800; display: flex; align-items: center; gap: 5px;">
                                        <i class="fas fa-star"></i> <%= shop.averageRating > 0 ? shop.averageRating.toFixed(1) : 'New' %>
                                        <span style="font-size: 0.7rem; color: var(--slate);">(<%= shop.totalReviews %>)</span>
                                    </div>
                                </td>
                                <td data-label="Status">
                                    <span class="status-badge <%= ownerExpired ? 'status-expired' : (shop.isOpen ? 'status-active' : 'status-warning') %>">
                                        <%= ownerExpired ? 'OWNER EXPIRED' : (shop.isOpen ? 'OPEN' : 'CLOSED') %>
                                    </span>
                                </td>
                                <td data-label="View" style="text-align: right;">
                                    <a href="/shop/<%= shop._id %>" target="_blank" style="background: #f1f5f9; color: var(--primary); padding: 8px 12px; border-radius: 8px; text-decoration: none; font-weight: 700; display: inline-block;">
                                        <i class="fas fa-external-link-alt"></i>
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="5" style="text-align: center; color: var(--slate); padding: 30px;">No shops registered on the platform yet.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

</div>

<%- include('partials/footer') %>