<%- include('partials/header') %>

<style>
    .requests-container { max-width: 1000px; margin: 40px auto; padding: 0 20px; }
    .booking-item-card { 
        background: white; border-radius: 16px; margin-bottom: 20px; 
        box-shadow: 0 4px 15px rgba(0,0,0,0.05); overflow: hidden; 
        border: 1px solid #f1f5f9; transition: 0.3s;
    }
    /* Status Border Logic */
    .status-accepted { border-left: 8px solid #10b981; }
    .status-pending { border-left: 8px solid #94a3b8; }
    .status-rejected { border-left: 8px solid #ef4444; }
    .status-rescheduled { border-left: 8px solid #f59e0b; }

    .btn-action-success { background: #10b981; color: white; border: none; padding: 10px 22px; border-radius: 8px; font-weight: 700; cursor: pointer; transition: 0.2s; }
    .btn-action-warning { background: #f59e0b; color: white; border: none; padding: 10px 22px; border-radius: 8px; font-weight: 700; cursor: pointer; transition: 0.2s; }
    .btn-action-danger { background: #ef4444; color: white; border: none; padding: 10px 22px; border-radius: 8px; font-weight: 700; cursor: pointer; transition: 0.2s; }
    .btn-action-success:hover { background: #059669; }
    
    .res-drawer { display: none; margin-top: 15px; padding: 15px; background: #f8fafc; border-radius: 12px; border: 1px dashed #cbd5e1; }
    .mini-input { padding: 10px; border: 1.5px solid #e2e8f0; border-radius: 8px; font-family: inherit; }
</style>

<div class="requests-container">
    <h2 style="font-size: 2rem; color: #1e293b; margin-bottom: 30px;">Customer Requests 📥</h2>

    <div class="requests-list">
        <% if (appointments && appointments.length > 0) { %>
            <% appointments.forEach(app => { %>
                <div class="booking-item-card status-<%= app.status.toLowerCase() %>">
                    <div style="padding: 25px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px;">
                        <div style="display: flex; gap: 20px; align-items: center;">
                            <div style="width: 55px; height: 55px; background: #e0f2fe; color: #0ea5e9; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1.2rem;">
                                <%= app.userId.name.charAt(0).toUpperCase() %>
                            </div>
                            <div>
                                <h3 style="margin: 0; font-size: 1.2rem;"><%= app.serviceId.serviceName %></h3>
                                <p style="margin: 3px 0; color: #475569; font-size: 0.9rem;"><strong>Customer:</strong> <%= app.userId.name %></p>
                                <div style="color: #64748b; font-size: 0.85rem; font-weight: 600; margin-top: 5px;">
                                    <i class="far fa-calendar-alt"></i> <%= new Date(app.bookingDate).toDateString() %> | <i class="far fa-clock"></i> <%= app.bookingTime %>
                                </div>
                            </div>
                        </div>
                        <div style="text-align: right;">
                            <h2 style="color: #059669; margin: 0;">₹<%= app.serviceId.price %></h2>
                            <span style="font-size: 0.7rem; font-weight: 800; text-transform: uppercase; color: #94a3b8;"><%= app.status %></span>
                        </div>
                    </div>

                    <div style="background: #f8fafc; padding: 15px 25px; border-top: 1px solid #f1f5f9;">
                        <form action="/owner/update-request" method="POST" style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
                            <input type="hidden" name="appointmentId" value="<%= app._id %>">

                            <button type="submit" name="status" value="Accepted" class="btn-action-success">Accept</button>
                            <button type="button" onclick="toggleRes('<%= app._id %>')" class="btn-action-warning">Reschedule</button>
                            <button type="submit" name="status" value="Rejected" class="btn-action-danger">Reject</button>

                            <div id="res-box-<%= app._id %>" class="res-drawer">
                                <div style="display: flex; gap: 10px; align-items: center;">
                                    <input type="date" name="proposedDate" class="mini-input">
                                    <input type="time" name="proposedTime" class="mini-input">
                                    <button type="submit" name="status" value="Rescheduled" style="background: #1e293b; color:white; border:none; padding:10px 15px; border-radius:8px; cursor:pointer; font-weight:600;">Confirm</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div style="text-align: center; padding: 60px; background: white; border-radius: 16px; border: 2px dashed #e2e8f0; color: #94a3b8;">
                <i class="fas fa-inbox" style="font-size: 3rem; margin-bottom: 15px;"></i>
                <p>No pending requests right now.</p>
            </div>
        <% } %>
    </div>
</div>

<script>
    function toggleRes(id) {
        const box = document.getElementById('res-box-' + id);
        box.style.display = (box.style.display === 'none' || box.style.display === '') ? 'block' : 'none';
    }
</script>

<%- include('partials/footer') %>