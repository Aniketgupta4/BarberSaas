<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'BarberSaaS' %></title>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<header class="main-header">
    <nav class="navbar container">
        <a href="/" class="nav-logo">
            <div class="logo-icon"><i class="fas fa-scissors"></i></div>
            <span>Barber<span>SaaS</span></span>
        </a>

        <ul class="nav-menu">
            <li class="nav-item"><a href="/" class="nav-link">Home</a></li>

            <% if (user) { %>
                <% if (user.role === 'SuperAdmin') { %>
                    <li class="nav-item"><a href="/admin/dashboard" class="nav-link">Admin Panel</a></li>
                
                <% } else if (user.role === 'BarberOwner') { %>
                    <li class="nav-item"><a href="/owner/dashboard" class="nav-link">Dashboard</a></li>
                    <li class="nav-item"><a href="/owner/manage" class="nav-link">Manage Shop</a></li>
                    <li class="nav-item"><a href="/owner/requests" class="nav-link">Requests</a></li>
                
                <% } else { %>
                    <li class="nav-item"><a href="/user/dashboard" class="nav-link">My Bookings</a></li>
                <% } %>

                <li class="nav-item">
                    <a href="/logout" class="nav-link logout-btn">
                        Logout <i class="fas fa-sign-out-alt"></i>
                    </a>
                </li>

            <% } else { %>
                <li class="nav-item"><a href="/login" class="nav-link">Login</a></li>
                <li class="nav-item"><a href="/signup" class="nav-link signup-cta">Get Started</a></li>
            <% } %>
        </ul>

        <div class="hamburger" id="hamburger">
            <span class="line"></span>
            <span class="line"></span>
            <span class="line"></span>
        </div>
    </nav>
</header>

<div style="height: 80px;"></div>